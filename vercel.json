{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/case-data.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
